/*
 * MimiClaw Build-time Secrets
 *
 * This is the ONLY way to configure MimiClaw.
 * Copy this file to mimi_secrets.h and fill in your values.
 * After any change, rebuild: idf.py fullclean && idf.py build
 *
 *   cp mimi_secrets.h.example mimi_secrets.h
 */

#pragma once

/* WiFi */
#define MIMI_SECRET_WIFI_SSID       ""
#define MIMI_SECRET_WIFI_PASS       ""

/* Telegram Bot */
#define MIMI_SECRET_TG_TOKEN        ""

/* Feishu Bot */
#define MIMI_SECRET_FEISHU_APP_ID   ""
#define MIMI_SECRET_FEISHU_APP_SECRET ""

/* Anthropic API */
#define MIMI_SECRET_API_KEY         ""
#define MIMI_SECRET_MODEL           ""
#define MIMI_SECRET_MODEL_PROVIDER  "anthropic"

/* HTTP Proxy (leave empty or set both) */
#define MIMI_SECRET_PROXY_HOST      ""
#define MIMI_SECRET_PROXY_PORT      ""
#define MIMI_SECRET_PROXY_TYPE      ""   /* "http" or "socks5" */

/* Brave Search API */
#define MIMI_SECRET_SEARCH_KEY      ""
/* Tavily Search API */
#define MIMI_SECRET_TAVILY_KEY      ""

/* Onboard RGB LED (change if your board uses a different WS2812 pin) */
#define MIMI_SECRET_WS2812_GPIO     48

/* Servo motor (optional; defaults to GPIO 5 if unset) */
#define MIMI_SECRET_SERVO_GPIO      5

/* DHT11 legacy sensor data pin (unused when AHT10 is enabled below) */
#define MIMI_SECRET_DHT11_GPIO      3

/* AHT10 temperature/humidity sensor I2C wiring */
#define MIMI_SECRET_AHT10_SDA_GPIO  21
#define MIMI_SECRET_AHT10_SCL_GPIO  18
#define MIMI_SECRET_AHT10_I2C_PORT  0
#define MIMI_SECRET_AHT10_SCL_HZ    100000
#define MIMI_SECRET_AHT10_ADDR      0x38

/* 3-wire human presence/PIR sensor OUT pin: VCC, GND, OUT */
#define MIMI_SECRET_PRESENCE_GPIO   (-1)

/* HC-SR05 ultrasonic presence/proximity sensor.
 * Power the module from 5V, share GND, and protect Echo with a divider or level shifter before ESP32 input.
 * Leave pins as -1 to require per-call trig_gpio/echo_gpio overrides.
 */
#define MIMI_SECRET_HC_SR05_TRIG_GPIO (-1)
#define MIMI_SECRET_HC_SR05_ECHO_GPIO (-1)
#define MIMI_SECRET_HC_SR05_PRESENT_THRESHOLD_CM 80

/* RPi MQTT sensor pipe.
 * Leave broker empty to disable this background publisher.
 * Payload published to sensor/data:
 *   {"temp":25.6,"humidity":68.3,"co2":450}
 */
#define MIMI_SECRET_SENSOR_MQTT_BROKER ""
#define MIMI_SECRET_SENSOR_MQTT_PORT 1883
#define MIMI_SECRET_SENSOR_DHT22_GPIO 4
#define MIMI_SECRET_SENSOR_MHZ19_UART_NUM 1
#define MIMI_SECRET_SENSOR_MHZ19_RX_GPIO 16
#define MIMI_SECRET_SENSOR_MHZ19_TX_GPIO 17
#define MIMI_SECRET_SENSOR_MQTT_PUBLISH_INTERVAL_MS 5000

/* SGP30 hardware I2C1 wiring for 3-I2C combined tests */
#define MIMI_SECRET_SGP30_SDA_GPIO  14
#define MIMI_SECRET_SGP30_SCL_GPIO  15
#define MIMI_SECRET_SGP30_I2C_PORT  1
#define MIMI_SECRET_SGP30_SCL_HZ    100000

/* MAX98357 I2S audio amplifier wiring. */
#define MIMI_SECRET_MAX98357_BCLK_GPIO 1
#define MIMI_SECRET_MAX98357_WS_GPIO   2
#define MIMI_SECRET_MAX98357_DIN_GPIO  3
#define MIMI_SECRET_MAX98357_SD_GPIO   (-1)
#define MIMI_SECRET_MAX98357_I2S_PORT  0
#define MIMI_SECRET_MAX98357_SAMPLE_RATE_HZ 16000
#define MIMI_SECRET_MAX98357_DEFAULT_TONE_HZ 440
#define MIMI_SECRET_MAX98357_DEFAULT_DURATION_MS 2000
#define MIMI_SECRET_MAX98357_DEFAULT_VOLUME_PCT 70

/* GY-30 / BH1750 software I2C wiring.
 * Default ADDR low/open address is 0x23; ADDR high is 0x5C.
 */
#define MIMI_SECRET_BH1750_SDA_GPIO 11
#define MIMI_SECRET_BH1750_SCL_GPIO 12
#define MIMI_SECRET_BH1750_I2C_PORT 0
#define MIMI_SECRET_BH1750_SCL_HZ   100000
#define MIMI_SECRET_BH1750_ADDR     0x23
